<?php

namespace Scf\Mode\Web\Request;

use Scf\Core\ComponentTrait;
use Scf\Helper\StringHelper;

const _MOBILE = '__MOBILE__';
const _EMAIL = '__EMAIL__';
const _REQUIRED = '__REQUIRED__';

class Filter {
    use ComponentTrait;

    protected string $filter;
    protected string $message;

    public static function required($msg): Filter {
        return static::factory()->setFilter(_REQUIRED, $msg);
    }

    /**
     * @param $filter
     * @param $msg
     * @return Filter
     */
    public static function match($filter, $msg): Filter {
        return static::factory()->setFilter($filter, $msg);
    }

    /**
     * @param $filter
     * @param $msg
     * @return $this
     */
    protected function setFilter($filter, $msg): static {
        $this->filter = $filter;
        $this->message = $msg;
        return $this;
    }

    /**
     * @return string
     */
    public function getMessage(): string {
        return $this->message;
    }

    /**
     * @param $val
     * @return bool
     */
    public function isValid($val): bool {
        return match ($this->filter) {
            _MOBILE => StringHelper::is_mobile_number($val),
            _REQUIRED => !is_null($val) && $val != '',
            _EMAIL => false,
            default => true,
        };
    }
}