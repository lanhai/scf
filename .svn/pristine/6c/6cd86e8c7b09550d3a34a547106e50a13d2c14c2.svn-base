<?php

namespace Scf\Mode\Web\Request;

use Scf\Core\Component;
use Scf\Mode\Web\Request;

class Requirement extends Component {

    /**
     * @param ...$vars
     * @return array
     */
    public function all(&...$vars): array {
        $data = [];
        $index = 0;
        foreach ($this->_config as $key => $msg) {
            $data[$key] = Request::instance()->_all($key, Request::REQUIRED, $msg);
            $vars[$index] = $data[$key];
            $index++;
        }
        return $data;
    }

    /**
     * @param ...$vars
     * @return array
     */
    public function get(&...$vars): array {
        $data = [];
        $index = 0;
        foreach ($this->_config as $key => $msg) {
            $data[$key] = Request::instance()->_get($key, Request::REQUIRED, $msg);
            $vars[$index] = $data[$key];
            $index++;
        }
        return $data;
    }

    /**
     * @param ...$vars
     * @return array
     */
    public function post(&...$vars): array {
        $data = [];
        $index = 0;
        foreach ($this->_config as $key => $msg) {
            $data[$key] = Request::instance()->_post($key, Request::REQUIRED, $msg);
            $vars[$index] = $data[$key];
            $index++;
        }
        return $data;
    }

}