<?php

namespace Scf\Service\Enum;

use Scf\Core\EnumMatcher;

enum QueueStatus: int {
    use EnumMatcher;

    case IN = 0;
    case FINISHED = 1;
    case DELAY = 2;
    case FAILED = -1;

    /**
     * 获取状态key
     * @return string
     */
    public function key(): string {
        return APP_ID . '_QUEUE_LIST_' . $this->value;
    }

    /**
     * 匹配状态key
     * @param $value
     * @return string
     */
    public static function matchKey($value): string {
        $case = self::match($value);
        return $case ? $case->key() : self::IN->key();
    }

}