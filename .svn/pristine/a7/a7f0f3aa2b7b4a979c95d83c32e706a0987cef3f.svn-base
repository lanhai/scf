namespace Scf\Component;

use Scf\Database\Redis;
use Scf\Mode\Web\Request;
use Scf\Mode\Web\Response;
use Scf\Session\ISession;
use Scf\Util\Arr;
use Scf\Core\CoroutineComponent;

class Session extends CoroutineComponent {

    const FLUSH_KEY = '__FLUSH__';

    protected array $_config = [
        'prefix' => null, // SESSION名称前缀
        'name' => null,
        'path' => null,
        'domain' => null,
        'expire' => null,
        'use_trans_sid' => null,
        'use_cookies' => null,
        'cache_limiter' => null,
        'cache_expire' => null,
        'var_id' => null, // GET方式Session ID的变量名
        'auto_start' => true,
    ];
    protected string $_prefix = '';
    protected ?string $sessionId = null;

    protected function _init() {
        $this->_prefix = is_null($this->_config['prefix']) ? '' : $this->_config['prefix'];
//        if (!is_null($this->_config['var_id']))
//            session_id($_REQUEST[$this->_config['var_id']]);
//        if (!is_null($this->_config['name']))
//            session_name($this->_config['name']);
//        if (!is_null($this->_config['path']))
//            session_save_path($this->_config['path']);
//        if (!is_null($this->_config['domain']))
//            ini_set('session.cookie_domain', $this->_config['domain']);
//        if (!is_null($this->_config['use_trans_sid']))
//            ini_set('session.use_trans_sid', $this->_config['use_trans_sid'] ? 1 : 0);
//        if (!is_null($this->_config['use_cookies']))
//            ini_set('session.use_cookies', $this->_config['use_cookies'] ? 1 : 0);
//        if (!is_null($this->_config['cache_limiter']))
//            session_cache_limiter($this->_config['cache_limiter']);
//        if (!is_null($this->_config['cache_expire']))
//            session_cache_expire($this->_config['cache_expire']);

        print_r($this->_config);
        $sessionId = Request::instance()->cookie('PHPSESSID');
        if (!$sessionId)
            session_start();
        $this->sessionId = APP_ID . '_SESSION_' . $sessionId;
    }

    /**
     * 读取
     * @param string|null $name 支持.语法
     * @param mixed|null $default
     * @return mixed
     */
    public function get(string $name = null, mixed $default = null): mixed {
        if ($this->_prefix) {
            $name = $this->_prefix . $name;
        }
        if (is_null($name)) {
            $result = Redis::pool()->hgetAll($this->sessionId);
        } else {
            $result = Redis::pool()->hget($this->sessionId, $name);
        }
        if ($result) {
            Redis::pool()->expire($this->sessionId, $this->_config['expire']);
        }
        return $result;
    }

    /**
     * 赋值
     * @param string $name
     * @param $value
     * @return bool|int
     */
    public function set(string $name, $value): bool|int {
        if ($this->_prefix) {
            $name = $this->_prefix . $name;
        }
        $set = Redis::pool()->hset($this->sessionId, $name, $value);
        Redis::pool()->expire($this->sessionId, $this->_config['expire']);
        return $set;
    }

    /**
     * 删除一个session,不支持.语法
     * @param string $name
     */
    public function del(string $name) {
        if ($this->_prefix) {
            unset($_SESSION[$this->_prefix][$name]);
        } else {
            unset($_SESSION[$name]);
        }
    }

    /**
     * 清空session
     */
    public function clean() {
        if ($this->_prefix) {
            $_SESSION[$this->_prefix] = [];
        } else {
            $_SESSION = [];
        }
    }

    /**
     * 全局读取,不带前缀
     * @param string|null $name 支持.语法
     * @param mixed|null $default
     * @return mixed
     */
    public function getGlobal(string $name = null, mixed $default = null): mixed {
        if (is_null($name)) {
            return $_SESSION;
        }
        return Arr::path($_SESSION, $name, $default, '.');
    }

    /**
     * 全局赋值,不带前缀
     * @param string $name 支持.语法
     * @param $value
     */
    public function setGlobal(string $name, $value) {
        Arr::setPath($_SESSION, $name, $value, '.');
    }

    /**
     * 全局删除一个session,不支持.语法
     * @param string $name
     */
    public function delGlobal(string $name) {
        unset($_SESSION[$name]);
    }

    /**
     * 设置单次session, 读取一次后消失
     * @param $name
     * @param $value
     */
    public function setFlush($name, $value) {
        if ($this->_prefix) {
            if (!isset($_SESSION[$this->_prefix]['__FLUSH__'])) {
                $_SESSION[$this->_prefix][self::FLUSH_KEY] = [];
            }
            $_SESSION[$this->_prefix][self::FLUSH_KEY][$name] = $value;
        } else {
            if (!isset($_SESSION[self::FLUSH_KEY])) {
                $_SESSION[self::FLUSH_KEY] = [];
            }
            $_SESSION[self::FLUSH_KEY][$name] = $value;
        }
    }

    /**
     * 读取单次session
     * @param $name
     * @param mixed|null $default
     * @return mixed|null
     */
    public function getFlush($name, mixed $default = null): mixed {
        if ($this->_prefix) {
            if (isset($_SESSION[$this->_prefix][self::FLUSH_KEY][$name])) {
                $value = $_SESSION[$this->_prefix][self::FLUSH_KEY][$name];
                unset($_SESSION[$this->_prefix][self::FLUSH_KEY][$name]);
                return $value;
            }
        } else {
            if (isset($_SESSION[$this->_prefix][self::FLUSH_KEY][$name])) {
                $value = $_SESSION[$this->_prefix][self::FLUSH_KEY][$name];
                unset($_SESSION[$this->_prefix][self::FLUSH_KEY][$name]);
                return $value;
            }
        }

        return $default;
    }

    /**
     * 开启session
     */
    public function start() {
        session_start();
    }

    /**
     * 暂停session
     */
    public function pause() {
        session_write_close();
    }

    /**
     * 销毁session,包括所有的前缀
     */
    public function destroy() {
        $_SESSION = [];
        session_unset();
        session_destroy();
    }

    /**
     * 重新生成session id
     */
    public function regenerate() {
        session_regenerate_id();
    }
}
