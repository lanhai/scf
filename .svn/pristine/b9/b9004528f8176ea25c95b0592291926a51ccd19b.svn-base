<?php

namespace Scf\Server;

use Scf\Command\Color;
use Scf\Command\Manager;
use Scf\Core\Config;
use Scf\Core\Console;
use Scf\Core\Env;
use Scf\Helper\JsonHelper;
use Scf\Mode\Web\App;
use Scf\Mode\Web\Exception\AppError;
use Scf\Mode\Web\Exception\NotFoundException;
use Scf\Mode\Web\Log;
use Scf\Mode\Web\Updater;
use Scf\Runtime\Table;
use Scf\Server\Struct\NodeStruct;
use Scf\Util\Dir;
use Swoole\Coroutine;
use Swoole\ExitException;
use Swoole\Http\Request;
use Swoole\Http\Response;
use Swoole\Runtime;
use Swoole\Timer;
use Swoole\WebSocket\Server;
use Throwable;

class Http extends \Scf\Core\Server {

    /**
     * @var Server
     */
    protected Server $server;

    /**
     * @var string 当前服务器角色
     */
    protected string $role;
    /**
     * @var string id号
     */
    protected string $id = '';
    /**
     * @var string 绑定ip
     */
    protected string $bindHost = '127.0.0.1';
    /**
     * @var int 绑定端口
     */
    protected int $bindPort = 9502;
    /**
     * @var string 本机ip地址
     */
    protected string $ip;
    /**
     * @var string 节点名称
     */
    protected string $name;

    /**
     * @var int 启动时间
     */
    protected int $started = 0;
    /**
     * @var int 重启次数
     */
    protected int $restartTimes = 0;
    /**
     * @var bool 服务是否可用
     */
    protected bool $serviceEnable = false;
    /**
     * @var Updater
     */
    protected Updater $updater;

    protected BgTask $bgTaskManager;

    public static Server $master;


    /**
     * @param $role
     * @param string $host
     * @param int $port
     */
    public function __construct($role, string $host = '127.0.0.1', int $port = 9502) {
        $this->bindHost = $host;
        $this->bindPort = $port;
        $this->role = $role;
        $this->started = time();
        $this->name = SERVER_NAME;
        $this->id = SERVER_NODE_ID;
        $ips = swoole_get_local_ip();
        foreach ($ips as $ip) {
            $this->ip = $ip;
            break;
        }
        if (APP_RUN_MODE == 'phar') {
            $this->updater = Updater::instance();
        }
    }


    /**
     * 创建一个服务器对象
     * @param $role
     * @param string $host
     * @param int $port
     * @return Http
     */
    public static function create($role, string $host = '127.0.0.1', int $port = 9502): static {
        $class = get_called_class();
        if (!isset(self::$_instances[$class])) {
            self::$_instances[$class] = new $class($role, $host, $port);
        }
        return self::$_instances[$class];
    }

    /**
     * 启动服务
     * @return void
     */
    public function run() {
        Runtime::enableCoroutine();
        $this->bgTaskManager = BgTask::instance();
        //初始化内存表格
        $tables = [
            'Scf\Server\Table\LogTable',
            'Scf\Server\Table\Counter',
            'Scf\Server\Table\Runtime',
        ];
        Table::register($tables);
        //实例化服务器
        $this->server = new Server($this->bindHost);
        self::$master = $this->server;
        $setting = [
//            'document_root' => APP_PATH . 'public', // v4.4.0以下版本, 此处必须为绝对路径
//            'enable_static_handler' => true,
//            'http_autoindex' => true,
//            'http_index_files' => ['index.html'],
            'worker_num' => 10,
            'max_wait_time' => 60,
            'reload_async' => true,
            'daemonize' => Manager::instance()->issetOpt('d'),
            'log_file' => APP_PATH . 'log/server.log',
            'pid_file' => SERVER_MASTER_PID_FILE
        ];
        if (Env::isDev()) {
            $setting['document_root'] = APP_PATH . 'public';
            $setting['enable_static_handler'] = true;
            $setting['http_autoindex'] = true;
            $setting['http_index_files'] = ['index.html'];
        }
        $this->server->set($setting);
        //监听HTTP请求
        try {
            $httpPort = $this->server->listen($this->bindHost, $this->bindPort, SWOOLE_SOCK_TCP);
            $httpPort->set([
                'open_http_protocol' => true,
                'open_http2_protocol' => true,
                'open_websocket_protocol' => false
            ]);
            //监听SOCKET请求
            $socketPort = $this->server->listen($this->bindHost, $this->bindPort + 1, SWOOLE_SOCK_TCP);
            $socketPort->set([
                'open_http_protocol' => false,
                'open_http2_protocol' => false,
                'open_websocket_protocol' => true
            ]);
        } catch (\Throwable $exception) {
            Console::log(Color::red('启动失败:' . $exception->getMessage()));
            exit(1);
        }
        //处理HTTP请求
        $this->server->on('request', function ($request, $response) {
            $this->handleRequest($request, $response);
        });
        $this->server->on('WorkerError', function ($server, int $worker_id, int $worker_pid, int $exit_code, int $signal) {
            $this->log('worker #' . $worker_id . ' 发生致命错误:' . $signal);
        });
        //握手
        $this->server->on('handshake', function (Request $request, Response $response) {
            //$username = $request->get['username'] ?? 'guest';
            $password = $request->get['password'] ?? '';
            if (!$password || $password != md5(APP_AUTH_KEY)) {
                $response->status(403);
                $response->end();
            } else {
                $headers = $this->handleWebsocketShake($request, $response);
                foreach ($headers as $key => $val) {
                    $response->header($key, $val);
                }
                $response->status(101);
                $response->end();
                $fd = $request->fd;
                $this->server->defer(function () use ($fd) {
                    $this->server->push($fd, "hello");
                });
            }
        });
//        //WebSocket连接打开事件,只有未设置handshake回调时此回调才生效
//        $this->server->on('open', function (Server $server, Request $request) {
//            print_r($request);
//            $server->push($request->fd, "未授权的请求");
//            $server->close($request->fd);
//        });
//        $this->server->on('connect', function (Server $server, $clientId) {
//            $client = $this->server->getClientInfo($clientId);
//            $this->log('新连接:' . $client['remote_ip']);
//        });
        $this->server->on('message', function (Server $server, $frame) {
            switch ($frame->data) {
                case 'log_subscribe':
                    Console::subscribe($frame->fd);
                    $this->log("【日志订阅】 from {$frame->fd}:{$frame->data}");//,opcode:{$frame->opcode},fin:{$frame->finish}\n
                    $server->push($frame->fd, "日志订阅成功!会话ID:" . $frame->fd);
                    break;
                case 'reload':
                    $this->log("【重启请求】 from {$frame->fd}:{$frame->data}");//,opcode:{$frame->opcode},fin:{$frame->finish}\n
                    $server->push($frame->fd, "start reload");
                    $this->server->reload();
                    break;
                case 'version':
                    $version = $this->updater->getVersion();
                    $server->push($frame->fd, JsonHelper::toJson($version));
                    break;
                case 'update':
                    if ($this->forceUpdate()) {
                        $server->push($frame->fd, "更新成功");
                    } else {
                        $server->push($frame->fd, "更新失败");
                    }
                    break;
                default:
                    $this->log("【收到消息】 from {$frame->fd}:{$frame->data}");//,opcode:{$frame->opcode},fin:{$frame->finish}\n
                    $server->push($frame->fd, "message received:" . $frame->data);
                    break;
            }
        });
        $this->server->on('close', function (Server $server, $fd) {
            if ($server->isEstablished($fd)) {
                Console::unsubscribe($fd);
            }
            //$this->log("【断开连接】 from {$fd}");
        });
        $this->server->on("BeforeReload", function (Server $server) {
            //即将重启
            $clients = $this->server->getClientList(0);
            if ($clients) {
                foreach ($clients as $fd) {
                    if ($server->isEstablished($fd)) {
                        Console::unsubscribe($fd);
                    }
                }
            }
        });
        $this->server->on("AfterReload", function ($server) {
            $this->restartTimes += 1;
            \Scf\Server\Table\Runtime::instance()->set('restart_times', $this->restartTimes);
            $this->log('第' . $this->restartTimes . '次重启完成');
        });
        //worker启动完成
        $this->server->on('WorkerStart', function (Server $server, $workerId) {
            Config::init();
            App::loadModules();
            Log::instance()->enableTable();
            Console::enablePush();
            if ($workerId == 0) {
                App::loadBackgroundTasks();
                if ($this->bgTaskManager->hasTask()) {
                    $this->bgTaskManager->start();
                }
            }
        });
        //服务器完成启动
        $this->server->on('start', function ($server) {
            $masterPid = $server->master_pid;
            $managerPid = $server->manager_pid;
            define("SERVER_MASTER_PID", $masterPid);
            define("SERVER_MANAGER_PID", $managerPid);
            Config::init();
            Log::instance()->enableTable();
            $role = APP_ROLE;
            $env = APP_ENV;
            $mode = APP_RUN_MODE;
            $alias = APP_ALIAS;
            $files = count(get_included_files());
            $info = <<<INFO
-----------------------------
节点名称：{$alias}
运行环境：{$env}
运行模式：{$mode}
节点角色：{$role}
监听地址：{$this->bindHost}:{$this->bindPort}
管理进程：{$masterPid}
文件加载：{$files}
-----------------------------
INFO;
            Console::write(Color::yellow($info));
            //$this->log('【' . APP_ROLE . '·' . APP_ENV . '·' . APP_RUN_MODE . '】节点启动成功!listen ' . $this->bindHost . ':' . $this->bindPort . ',master pid:' . $masterPid . ',manager pid:' . $managerPid);
            $this->onStart();
        });
        $this->server->start();
    }

    /**
     * 服务器完成启动
     * @return void
     */
    protected function onStart() {
        //日志推送DEBUG
//        Coroutine::create(function () {
//            Timer::tick(1, function () {
//                //if (Console::hasSubscriber()) {
//                Console::write("来自节点" . $this->name . "的日志推送演示,当前时间:" . date('m-d H:i:s'));
//                //}
//            });
//        });
        Env::isDev() and $this->watchFileChange();
        //判断redis是否可用
        if (!\Scf\Database\Redis::available()) {
            Console::log(Color::red('redis不可用,请先配置相关参数'));
        } else {
            //$this->report();
            $this->heartbeat();
            $this->backupLog();
        }
        $this->checkVersion();
    }

    /**
     * 检查版本
     * @return void
     */
    protected function checkVersion() {
        if (APP_RUN_MODE != 'phar') {
            $this->enable();
            return;
        }
        $versionInfo = "";
        $updater = $this->updater;
        $version = $updater->getVersion();
        Console::line();
        $versionInfo .= "APP版本:" . $version['local']['version'] . ",更新时间:" . $version['local']['updated'] . "\n";
        $versionInfo .= "SCF版本:" . SCF_VERSION . ",更新时间:" . date('Y-m-d H:i:s') . "\n";
        if (is_null($version['remote'])) {
            $versionInfo .= "最新版本:获取失败\n";
        } else {
            $versionInfo .= "APP最新版本:" . (!$updater->hasNewAppVersion() ? Color::green("已是最新") : $version['remote']['app']['version'] . ",发布时间:" . $version['remote']['app']['release_date']) . "\n";
            $versionInfo .= "SCF最新版本:" . (!$updater->hasNewScfVersion() ? Color::green("已是最新") : $version['remote']['scf']['version'] . ",发布时间:" . $version['remote']['scf']['release_date']) . "\n";
        }
        $versionInfo .= "自动更新:" . ($updater->isEnableAutoUpdate() ? Color::green("开启") : Color::yellow("关闭"));
        Console::write($versionInfo);
        Console::line();
        if ($updater->hasNewAppVersion() && ($updater->isEnableAutoUpdate() || $version['remote']['app']['forced'] == true)) {
            $this->log('开始执行更新');
            if ($updater->updateApp()) {
                $this->server->reload();
                $this->enable();
                $this->log('更新完成');
            }
        } else {
            $this->enable();
        }
        $pid = Coroutine::create(function () use ($version) {
            $this->autoUpdate();
        });
        $this->log('自动更新服务启动成功!协程ID:' . $pid);
    }

    /**
     * 自动更新
     * @return mixed
     */
    protected function autoUpdate(): mixed {
        Coroutine::sleep(10);
        $updater = $this->updater;
        $version = $updater->getVersion();
        if ($updater->hasNewAppVersion()) {
            //强制更新
            if ($updater->isEnableAutoUpdate() || $version['remote']['app']['forced'] == true) {
                $this->disable();
                $this->log('开始执行更新:' . $version['remote']['app']['version']);
                if ($updater->updateApp()) {
                    $this->server->reload();
                    $this->log('更新完成:' . $version['remote']['app']['version']);
                    $this->enable();
                } else {
                    $this->log('更新失败:' . $version['remote']['app']['version']);
                }
            } else {
                //$this->log('检测到新版本:' . $version['remote']['app']['version']);
            }
        }
        return $this->autoUpdate();
    }

    /**
     * 强制更新到指定版本
     * @param $version
     * @return bool
     */
    protected function forceUpdate($version = null): bool {
        $updater = $this->updater;
        if (!$updater->hasNewAppVersion()) {
            return false;
        }
        $this->disable();
        if (!is_null($version)) {
            $this->log('开始执行更新:' . $version);
            if ($updater->changeAppVersion($version)) {
                $this->server->reload();
                $this->log('更新完成:' . $version);
                $this->enable();
                return true;
            } else {
                $this->log('更新失败:' . $version);
            }
        } else {
            $version = $updater->getVersion();
            $this->log('开始执行更新:' . $version['remote']['app']['version']);
            if ($updater->updateApp()) {
                $this->server->reload();
                $this->log('更新完成:' . $version['remote']['app']['version']);
                $this->enable();
                return true;
            } else {
                $this->log('更新失败:' . $version['remote']['app']['version']);
            }
        }
        return false;
    }

    /**
     * 转存内存table的日志到redis和日志文件
     * @return void
     */
    protected function backupLog() {
        $pid = Coroutine::create(function () {
            $logger = Log::instance();
            Timer::tick(3000, function () use ($logger) {
                $count = $logger->backup();
                $count > 0 and $this->log('本次同步转存日志:' . $count);
            });
        });
        $this->log('日志备份启动完成!协程ID:' . $pid);
    }

    /**
     * 发送心跳包
     * @return void
     */
    protected function heartbeat() {
        //延迟一秒执行避免和 WorkerStart 事件后的节点报到事件抢redis锁
        Coroutine::sleep(1);
        $manager = \Scf\Server\Manager::instance();
        $pid = Coroutine::create(function () use ($manager) {
            Timer::tick(1000, function () use ($manager) {
                $manager->heartbeat($this->id);
                Coroutine::sleep(1);
            });
        });
        $this->log('节点心跳报到服务启动完成!协程ID:' . $pid);
    }

    /**
     * 监听文件改动自动重启服务
     * @return void
     */
    protected function watchFileChange() {
        $pid = Coroutine::create(function () {
            if (APP_RUN_MODE == 'src') {
                $appFiles = Dir::getDirFiles(APP_PATH . '/src');
            } else {
                $appFiles = [];
                // $appFiles = [SCF_ROOT . '/' . APP_ID . '.app'];
            }
            $files = [...$appFiles, ...Dir::getDirFiles(SCF_ROOT . '/lib/scf')];
            $fileList = [];
            foreach ($files as &$path) {
                $fileList[] = [
                    'path' => $path,
                    'md5' => md5_file($path)
                ];
            }
            while (true) {
                foreach ($fileList as $key => &$file) {
                    $getMd5 = md5_file($file['path']);
                    if (strcmp($file['md5'], $getMd5) !== 0) {
                        $file['md5'] = $getMd5;
                        $this->log($file['path'] . ' 文件属性发生改变,服务器即将重启');
                        $this->server->reload();
                    }
                }
                Coroutine::sleep(3);
            }
        });
        $this->log('文件改动监听服务启动完成!ID:' . $pid);
    }

    /**
     * 向节点管理员报到
     * @return void
     */
    protected function report() {
        $manager = \Scf\Server\Manager::instance();
        $node = NodeStruct::factory();
        $node->appid = APP_ID;
        $node->id = $this->id;
        $node->name = $this->name;
        $node->ip = $this->ip;
        $node->port = APP_PORT;
        $node->socketPort = APP_PORT + 1;
        $node->role = $this->role;
        $node->started = $this->started;
        $node->restart_times = $this->restartTimes;
        $node->master_pid = SERVER_MASTER_PID;
        $node->manager_pid = SERVER_MANAGER_PID;
        try {
            $manager->report($node);
        } catch (\Exception $exception) {
            $this->server->stop();
            $this->log($exception->getMessage());
        }
    }

    /**
     * 向socket客户端推送内容
     * @param $fd
     * @param $str
     * @return false|mixed
     */
    public function push($fd, $str): mixed {
        try {
            return $this->server->push($fd, $str);
        } catch (Throwable) {
            return false;
        }
    }

    /**
     * @return int
     */
    public function getReloadTimes(): int {
        return \Scf\Server\Table\Runtime::instance()->get('restart_times');
    }

    /**
     * 处理HTTP请求
     * @param Request $request
     * @param Response $response
     * @return void
     */
    protected function handleRequest(Request $request, Response $response) {
        if ($request->server['path_info'] == '/favicon.ico' || $request->server['request_uri'] == '/favicon.ico') {
            $response->end();
            return;
        }
        if (!$this->isEnable()) {
            $response->status(503);
            $response->end("Service Unavailable!Try later");
            return;
        }
        \Scf\Mode\Web\Response::instance()->register($response);
        \Scf\Mode\Web\Request::instance()->register($request);
        $app = App::instance();
        $logger = Log::instance();
        Env::isDev() and $logger->enableDebug();
        try {
            $app->init();
            $result = $app->run();
            if ($result->hasError()) {
                \Scf\Mode\Web\Response::error($result->getMessage(), $result->getErrCode(), $result->getData());
            } else {
                \Scf\Mode\Web\Response::success($result->getData());
            }
        } catch (Throwable $exception) {
            if ($exception instanceof NotFoundException) {
                $app->handleNotFound();
            } elseif ($exception instanceof ExitException) {
                $exception->getStatus() != 200 and Console::log(Color::red('#' . Coroutine::getCid() . ' 线程退出:' . $exception->getStatus()));
            } else {
                $message = $exception->getMessage();
                $code = $exception->getCode();
                $file = $exception->getFile();
                $line = $exception->getLine();
                if ($exception instanceof AppError) {
                    $backTrace = $exception->getTrace();
                    $file = $backTrace[0]['file'] ?? $file;
                    $line = $backTrace[0]['line'] ?? $line;
                }
                $logger->error($message, $code, $file, $line);
                $app->handleError([
                    'code' => $code,
                    'error' => $message,
                    'file' => $file,
                    'line' => $line,
                    'time' => date('Y-m-d H:i:s'),
                    'trace' => $exception->getTrace(),
                    'ip' => $this->ip
                ]);
            }
        }
    }

    /**
     * 设置服务为可用状态
     * @return void
     */
    protected function enable() {
        $this->serviceEnable = true;
        \Scf\Server\Table\Runtime::instance()->set('_SERVER_STATUS_', 1);

    }

    /**
     * 设置服务为不可用状态
     * @return void
     */
    protected function disable() {
        $this->serviceEnable = false;
        \Scf\Server\Table\Runtime::instance()->set('_SERVER_STATUS_', 0);
    }

    /**
     * 服务是否可用
     * @return bool
     */
    protected function isEnable(): bool {
        $status = \Scf\Server\Table\Runtime::instance()->get('_SERVER_STATUS_');
        $this->serviceEnable = $status == 1;
        return $this->serviceEnable;
    }

    /**
     * 处理websocket握手
     * @param Request $request
     * @param Response $response
     * @return array|false
     */
    protected function handleWebsocketShake(Request $request, Response $response): bool|array {
        //websocket握手连接算法验证
        $secWebSocketKey = $request->header['sec-websocket-key'];
        $patten = '#^[+/0-9A-Za-z]{21}[AQgw]==$#';
        if (0 === preg_match($patten, $secWebSocketKey) || 16 !== strlen(base64_decode($secWebSocketKey))) {
            $response->end();
            return false;
        }
        $key = base64_encode(
            sha1(
                $request->header['sec-websocket-key'] . '258EAFA5-E914-47DA-95CA-C5AB0DC85B11',
                true
            )
        );
        $headers = [
            'Upgrade' => 'websocket',
            'Connection' => 'Upgrade',
            'Sec-WebSocket-Accept' => $key,
            'Sec-WebSocket-Version' => '13',
        ];
        // WebSocket connection to 'ws://127.0.0.1:9502/'
        // failed: Error during WebSocket handshake:
        // Response must not include 'Sec-WebSocket-Protocol' header if not present in request: websocket
        if (isset($request->header['sec-websocket-protocol'])) {
            $headers['Sec-WebSocket-Protocol'] = $request->header['sec-websocket-protocol'];
        }
        return $headers;
    }

    /**
     * @return Server|null
     */
    public static function master(): Server|null {
        return self::$master ?? null;
    }
}