<?php

namespace Scf\Component;

use Scf\Core\Component;
use Scf\Core\Console;
use Scf\Helper\JsonHelper;
use Scf\Mode\Web\Thread;
use Scf\Util\Sn;
use Scf\Util\Time;
use Simps\MQTT\Client;
use Simps\MQTT\Config\ClientConfig;

class SocketMessager extends Component {
    const SWOOLE_MQTT_CONFIG = [
        'open_mqtt_protocol' => true,
        'package_max_length' => 2 * 1024 * 1024,
        'connect_timeout' => 5.0,
        'write_timeout' => 5.0,
        'read_timeout' => 5.0,
    ];
    /**
     * @var Mqtt|Client
     */
    protected Mqtt|Client $client;

    /**
     * 发布广播
     * @param $type
     * @param $content
     * @return false
     */
    public function publish($type, $content): bool {
        if (!isset($this->client) && !$this->connect()) {
            Console::log('连接mqttserver失败');
            return false;
        }
        $millisecond = Time::millisecond();
        $message = [
            'type' => $type,
            'time' => date('Y-m-d H:i:s.') . substr($millisecond, -3),
            'env' => Thread::isDevEnv() ? 'dev' : 'pro',
            'content' => $content
        ];
        try {
            $this->client->publish($this->_config['topic'] ?? 'runtime_log', JsonHelper::toJson($message), 0, false);
        } catch (\Exception $exception) {
            Console::log('通知机器人失败:' . $exception->getMessage());
            unset($this->_client);
            return false;
        }
        return true;
    }

    protected function connect(): bool {
        $clientId = $this->_config['client_id'] . '_' . Sn::create_guid();
        $config = new ClientConfig();
        $config->setUserName('')
            ->setPassword('')
            ->setClientId($clientId)
            ->setKeepAlive(10)
            ->setDelay(3000) // 3s
            ->setMaxAttempts(5)
            ->setSwooleConfig(self::SWOOLE_MQTT_CONFIG);

        $client = new Client($this->_config['broker'], $this->_config['port'], $config);
        if (!$client->connect()) {
            return false;
        }
//        $client = new Mqtt($this->_config['broker'], $this->_config['port'], $clientId);
//        if (!$client->connect(true, NULL, $this->_config['username'], $this->_config['password'])) {
//            return false;
//        }
        $this->client = $client;
        return true;
    }


}