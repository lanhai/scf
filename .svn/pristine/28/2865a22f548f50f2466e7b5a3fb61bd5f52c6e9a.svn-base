<?php

namespace Scf\Server;

use Scf\Command\Handler\AppCreater;
use Scf\Command\Manager;
use Scf\Core\Console;
use Scf\Helper\ArrayHelper;
use Scf\Helper\JsonHelper;
use Scf\Util\File;

class Core {
    /**
     * 更新应用版本号
     * @param $appid
     * @param $version
     * @return bool
     */
    public static function updateAppVersion($appid, $version): bool {
        $config = SCF_APPS_ROOT . 'apps.json';
        $apps = self::getApps();
        $app = ArrayHelper::findColumn($apps, 'appid', $appid);
        if (!$app) {
            return false;
        }
        $app['version'] = $version;
        $app['updated'] = date('Y-m-d H:i:s');
        foreach ($apps as $k => $item) {
            if ($item['appid'] == $appid) {
                $apps[$k] = $app;
            }
        }
        return File::write($config, JsonHelper::toJson($apps));
    }

    /**
     * 应用信息
     * @param $appid
     * @return AppCreater|null
     */
    public static function appInfo($appid): AppCreater|null {
        if (!$appList = self::getApps()) {
            return null;
        }
        $app = ArrayHelper::findColumn($appList, 'appid', $appid);
        if (!$app) {
            return null;
        }
        return AppCreater::factory($app);
    }

    /**
     * 初始化
     * @return void
     */
    public static function initialize() {
        $manager = Manager::instance();
        $options = $manager->getOpts();
        $apps = self::getApps();
        if (!$apps) {
            Console::write('暂无应用');
            exit();
        }
        $path = $options['app'] ?? $apps[0]['app_path'];
        $app = ArrayHelper::findColumn($apps, 'app_path', $path);
        if (!$app) {
            Console::write('应用不存在');
            exit();
        }
        !defined('APP_ID') and define('APP_ID', $app['appid'] ?? 'scf_app');
        !defined('APP_PATH') and define('APP_PATH', SCF_APPS_ROOT . $path . '/');
        !defined('DB_REDIS') and define('DB_REDIS', APP_PATH . 'db/redis');
        !defined('APP_PUBLIC_PATH') and define('APP_PUBLIC_PATH', APP_PATH . $app['public_path']);
        !defined('APP_ALIAS') and define('APP_ALIAS', $options['alias'] ?? APP_ID);
        !defined('APP_ENV') and define('APP_ENV', $options['env'] ?? 'production');
        !defined('APP_ROLE') and define('APP_ROLE', $options['role'] ?? 'master');
        !defined('APP_PORT') and define('APP_PORT', $options['port'] ?? 9502);
        !defined('APP_AUTH_KEY') and define('APP_AUTH_KEY', $app['app_auth_key']);
        !defined('APP_RUN_MODE') and define('APP_RUN_MODE', $options['mode'] ?? (APP_ENV == 'production' ? 'phar' : 'src'));
        !defined('BG_TASK') and define('BG_TASK', $options['task'] ?? 'on');
        !defined('SERVER_NAME') and define('SERVER_NAME', $options['alisa'] ?? APP_ID);
        !defined('SERVER_ENABLE_STATIC_HANDER') and define('SERVER_ENABLE_STATIC_HANDER', isset($options['static']) && $options['static'] == 1);
        $ips = swoole_get_local_ip();
        foreach ($ips as $ip) {
            !defined('SERVER_HOST') and define('SERVER_HOST', $ip);
            break;
        }
        !defined('SERVER_NODE_ID') and define('SERVER_NODE_ID', strtolower(APP_ROLE) . '-' . md5(SERVER_NAME));
        !defined('SERVER_IS_MASTER') and define('SERVER_IS_MASTER', strtolower(APP_ROLE) == 'master');
        // 静态文件路径
        !defined('ASSET_PATH') and define('ASSET_PATH', APP_PUBLIC_PATH . 'asset/');
        //临时文件目录路径
        !defined('TMP_PATH') and define('TMP_PATH', APP_PATH . 'tmp/');
        //日志文件目录路径
        !defined('LOG_PATH') and define('LOG_PATH', APP_PATH . 'log/');
        //项目源码目录
        !defined('APP_PHAR_PATH') and define('APP_PHAR_PATH', APP_PATH . APP_ID . '.app');
        !defined('APP_SRC_PATH') and define('APP_SRC_PATH', APP_RUN_MODE == 'phar' ? 'phar://' . APP_PHAR_PATH . '/' : APP_PATH . 'src/');
        //项目视图目录
        !defined('APP_VIEW_PATH') and define('APP_VIEW_PATH', APP_SRC_PATH . 'template/');
        //项目库目录
        !defined('APP_LIB_PATH') and define('APP_LIB_PATH', APP_SRC_PATH . 'lib/');
        //文件更新目录
        !defined('APP_UPDATE_DIR') and define('APP_UPDATE_DIR', APP_PATH . 'update/');
        !defined('SERVER_MASTER_PID_FILE') and define('SERVER_MASTER_PID_FILE', SCF_ROOT . '/var/' . APP_ID . '.pid');
        !defined('SERVER_MASTER_DB_PID_FILE') and define('SERVER_MASTER_DB_PID_FILE', SCF_ROOT . '/var/' . APP_ID . '_master_db.pid');
        if (!file_exists(TMP_PATH)) {
            mkdir(TMP_PATH, 0775, true);
            mkdir(TMP_PATH . '/template', 0775, true);
        }
        if (!file_exists(SCF_ROOT . '/var')) {
            mkdir(SCF_ROOT . '/var', 0775, true);
        }
        if (!file_exists(LOG_PATH)) {
            mkdir(LOG_PATH, 0775, true);
        }
        if (!file_exists(APP_PATH . 'db')) {
            mkdir(APP_PATH . 'db', 0775, true);
        }
        if (!file_exists(APP_UPDATE_DIR)) {
            mkdir(APP_UPDATE_DIR, 0775, true);
        }
        if (!file_exists(APP_PUBLIC_PATH)) {
            mkdir(APP_PUBLIC_PATH, 0775, true);
        }
    }

    /**
     * 获取应用列表
     * @return array|bool|string
     */
    public static function getApps(): bool|array|string {
        $appConfig = SCF_APPS_ROOT . 'apps.json';
        if (!file_exists($appConfig)) {
            return false;
//            Console::write(Color::red('未查询到app配置文件:' . SCF_APPS_ROOT . 'apps.json'));
//            exit();
        }
        return File::readJson($appConfig);
    }
}