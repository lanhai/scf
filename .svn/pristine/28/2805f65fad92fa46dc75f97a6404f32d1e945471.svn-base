<?php

namespace Scf\Database\Exception;

use Scf\Core\Env;
use Scf\Mode\Web\Exception\AppError;

class NullAr {
    protected string $db;
    protected string $table;
    protected mixed $id;
    protected string $ar;

    public function __construct($db, $table, $id, $ar) {
        $this->db = $db;
        $this->table = $table;
        $this->id = $id;
        $this->ar = $ar;
    }

    /**
     * @throws AppError
     */
    public function __get($name) {
        if (Env::isDev()) {
            throw new AppError('活动记录数据不存在:' . $this->ar . ';id:' . $this->id);
        } else {
            throw new AppError('未查询到相关数据');
        }
    }

    /**
     * @throws AppError
     */
    public function __call($name, $args) {
        if (Env::isDev()) {
            throw new AppError('活动记录数据不存在:' . $this->ar . ';id:' . $this->id);
        } else {
            throw new AppError('未查询到相关数据');
        }
    }

    /**
     * @return bool
     */
    public function isNull(): bool {
        return true;
    }

    /**
     * @return bool
     */
    public function isNotNull(): bool {
        return false;
    }
}