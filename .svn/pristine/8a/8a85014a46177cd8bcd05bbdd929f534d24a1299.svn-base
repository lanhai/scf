<?php

namespace Scf\Component;

use Scf\Core\Component;
use Scf\Mode\Web\Thread;
use Scf\Util\Sn;
use Scf\Util\Time;

class SocketMessager extends Component {
    /**
     * @var Mqtt
     */
    protected Mqtt $client;

    /**
     * 发布广播
     * @param $type
     * @param $content
     * @return false
     */
    public function publish($type, $content): bool {
        if (!isset($this->_client)) {
            $this->connect();
        }
        $millisecond = Time::millisecond();
        $message = [
            'type' => $type,
            'time' => date('Y-m-d H:i:s.') . substr($millisecond, -3),
            'env' => Thread::isDevEnv() ? 'dev' : 'pro',
            'content' => $content
        ];
        try {
            $this->client->publish($this->_config['topic'] ?? 'runtime_log', json_encode($message, JSON_UNESCAPED_UNICODE), 0, false);
        } catch (\Exception) {
            unset($this->_client);
            return false;
        }
        return true;
    }

    protected function connect() {
        $clientId = $this->_config['client_id'] . '_' . Sn::create_guid();
        $client = new Mqtt($this->_config['broker'], $this->_config['port'], $clientId);
        if (!$client->connect(true, NULL, $this->_config['username'], $this->_config['password'])) {
            return false;
        }
        $this->client = $client;
    }


}